# .env is not pushed to git
# This file is a template indicating which variables should be included.

# StealthMole API key
STEALTHMOLE_BASE_URL=https://hackathon.stealthmole.com
STEALTHMOLE_ACCESS_KEY=
STEALTHMOLE_SECRET_KEY=

# The loader (src/d4d/config.py) also accepts the short names ACCESS_KEY /
# SECRET_KEY as a fallback, so an existing local .env using those will work:
# ACCESS_KEY=
# SECRET_KEY=

# Readiness API storage
# sqlite is the local/dev default. PostgreSQL can be attached without changing
# application services by setting D4D_STORAGE_BACKEND=postgres and D4D_DATABASE_URL.
D4D_STORAGE_BACKEND=sqlite
D4D_SQLITE_PATH=data/runtime/readiness.sqlite3
D4D_DATABASE_URL=

# OpenAI-compatible LLM endpoint.
# OPENAI_API_URL should include the /v1 base path when the provider expects it.
# D4D_LLM_* names are preferred by the app; OPENAI_* aliases are also accepted.
D4D_LLM_BASE_URL=https://api.openai.com/v1
D4D_LLM_API_KEY=
D4D_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1
